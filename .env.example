# App
APP_NAME=FinBot
APP_ENV=development
APP_DEBUG=true

# FastAPI
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# LangChain + NVIDIA
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_TEMPERATURE=0.2
NVIDIA_MAX_COMPLETION_TOKENS=512
NVIDIA_EMBEDDING_MODEL=meta/llama-3.1-70b-instruct-embedding-4k

# External financial APIs
# CoinGecko simple price endpoint does not require a key for basic usage.
COINGECKO_API_KEY=

# Semantic cache
SEMANTIC_CACHE_THRESHOLD=0.90

# RAG
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150

# Optional: OpenAI can be used later for Whisper/TTS if needed.
OPENAI_API_KEY=
